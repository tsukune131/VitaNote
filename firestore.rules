rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 各ユーザーは自分のデータだけ読み書きできる
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /{collection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
